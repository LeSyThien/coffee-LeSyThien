rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCTIONS (Dài hơn cho chuyên nghiệp) ---
    function isAuth() { return request.auth != null; }
    function isAdmin() { return isAuth() && request.auth.token.admin == true; }
    function isOwner(userId) { return isAuth() && request.auth.uid == userId; }
    
    // Kiểm tra dữ liệu không bị thay đổi (Immutable)
    function remainsUnchanged(key) {
      return request.resource.data[key] == resource.data[key];
    }

    // --- USERS ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuth() && isOwner(userId);
      allow update: if (
        isOwner(userId) && 
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["name", "phone", "updatedAt"])
      ) || (
        isAdmin() && 
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["name", "phone", "updatedAt", "balance", "role"])
      );
      allow delete: if isAdmin();
    }

    // --- PRODUCTS ---
    match /products/{id} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- ORDERS ---
    match /orders/{orderId} {
      allow read: if isAuth() && (isOwner(resource.data.userId) || isAdmin());
      
      allow create: if isAuth() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.total >= 0
        && request.resource.data.keys().hasAll(["userId", "items", "total", "status", "createdAt"]);

      allow update: if isAdmin()
        // Admin can change status: pending → shipping → completed/cancelled/rejected
        || (
          isOwner(resource.data.userId) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "completedAt"]) &&
          request.resource.data.status == "completed" &&
          remainsUnchanged("total") &&
          remainsUnchanged("userId")
        );

      allow delete: if isAdmin();
    }

    // --- TRANSACTIONS ---
    match /transactions/{txId} {
      allow read: if isAuth() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuth() 
        && isOwner(request.resource.data.userId)
        && request.resource.data.amount > 0
        && request.resource.data.keys().hasAll(["userId", "amount", "type", "status", "createdAt"]);
      allow update: if isAdmin() && request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "updatedAt"]);
      allow delete: if false;
    }

    // --- REVIEWS ---
    match /reviews/{id} {
      allow read: if true;
      allow create: if isAuth() 
        && isOwner(request.resource.data.userId)
        && request.resource.data.rating >= 1 
        && request.resource.data.rating <= 5;
      allow update: if (isOwner(resource.data.userId) && request.resource.data.diff(resource.data).changedKeys().hasOnly(["comment", "rating"]))
        || (isAdmin() && request.resource.data.diff(resource.data).changedKeys().hasOnly(["adminReply", "adminReplyAt"]));
      allow delete: if isAdmin();
    }

    // --- NOTIFICATIONS ---
    match /notifications/{id} {
      allow create: if isAuth() 
        && (isOwner(request.resource.data.userId) || isAdmin())
        && request.resource.data.keys().hasAll(["userId", "message", "createdAt"]);
      allow read: if isAuth() && (isOwner(resource.data.userId) || (resource.data.recipient == "admin" && isAdmin()));
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- DEPOSIT REQUESTS ---
    match /deposit_requests/{id} {
      allow read: if isAuth() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuth() && isOwner(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- CARTS (Cloud Sync) ---
    match /carts/{userId} {
      // Owner can read their own cart anytime
      allow read: if isOwner(userId);
      
      // Owner can create their own cart
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(["items", "total", "updatedAt"]);
      
      // Owner can update their own cart (unlimited item changes, total updates)
      // Admin can also manage carts if needed
      allow update: if (isOwner(userId) || isAdmin())
        && request.resource.data.keys().hasAll(["items", "total", "updatedAt"]);
      
      // Only admin can delete (for data cleanup)
      allow delete: if isAdmin();
    }

    // --- GLOBAL DENY ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}